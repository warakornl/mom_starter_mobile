{
  "expo": {
    "name": "Mom-Starter",
    "slug": "mom-starter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FBF6F1",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF6F1"
    },
    "scheme": "momstarter",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#A8505A",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-font",
      [
        "expo-calendar",
        {
          "calendarPermission": "แอปต้องการสิทธิ์เข้าถึงปฏิทินในเครื่อง เพื่อเพิ่มนัดหมายที่คุณบันทึกไว้ลงในปฏิทินของคุณ"
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.momstarter.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used to confirm your identity before permanently deleting your account and all associated data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF6F1"
      },
      "package": "com.momstarter.app",
      "permissions": [
        "USE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {}
  }
}
